<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">	
	<Import Project="TestProjectBefore.settings" />
  <PropertyGroup>

    <TargetFramework>v4.7.2</TargetFramework>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion> 
    <RunName>ptvs</RunName>
    <OutputPath>bin\RunSettings</OutputPath>
    <ResultsDirectory>.\TestResults</ResultsDirectory>
    <TargetPlatform>x64</TargetPlatform>
    <MaxCpuCount>1</MaxCpuCount>
    <TestSessionTimeout>3600000</TestSessionTimeout>
    <TestCaseFilter>Name=AddExistingFolder</TestCaseFilter>
    
    
	
  </PropertyGroup>
<!--
  <ItemGroup Label="Base RunSettings">
    <AdditionalSettings Include="$(BuildRoot)\Build\default.runsettings" />
  </ItemGroup> -->

  <ItemGroup Label="Test Stores">
    <TestStore Include="vstsdrop:$(TestStoreDropName)" />
  </ItemGroup>

  <ItemGroup Label="Test Containers">
    <TestContainer Include="PythonToolsTests.dll" />
  </ItemGroup>



	<Target Name="PrintPackagesPath" BeforeTargets="Build">
		<Message Importance="High" Text="PackagesPath=$(PackagesPath)" />
	</Target>
	<!--<ItemGroup>
		<PackageReference Include="Microsoft.DevDiv.Validation.TestPlatform.Settings.Tasks" Version="1.0.1108" />
	</ItemGroup>-->


  <PropertyGroup Label="Visual Studio Configuration">
    <DefaultComponentTypes>Recommended</DefaultComponentTypes>
  </PropertyGroup>
  <ItemGroup Label="Visual Studio Components">
    <IncludeComponent Include="Microsoft.VisualStudio.Component.VC.CLI.Support" />
    <IncludeComponent Include="Microsoft.VisualStudio.ComponentGroup.NativeDesktop.Win81" />
    <IncludeComponent Include="Microsoft.VisualStudio.ComponentGroup.UWP.VC" />
    <IncludeComponent Include="Microsoft.VisualStudio.Component.VC.Tools.x86.x64" />
    <IncludeComponent Include="Microsoft.VisualStudio.Component.VC.ATL.Spectre" />
    <IncludeComponent Include="Microsoft.VisualStudio.Component.VC.ATLMFC.Spectre" />
    <IncludeComponent Include="Microsoft.VisualStudio.Component.Debugger.VSOnline" />
    <IncludeComponent Include="Microsoft.VisualStudio.Component.Wcf.Tooling" />
    <IncludeComponent Include="Microsoft.NetCore.Component.Runtime.3.1" />
    <IncludeComponent Include="Microsoft.NetCore.Component.Runtime.5.0" />
    <IncludeComponent Include="Microsoft.Component.PythonTools"/>
  </ItemGroup>
  <ItemGroup Label="Visual Studio Workloads">
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.CoreEditor" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.ManagedDesktop" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.NativeCrossPlat" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.NativeDesktop" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.NetWeb" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.Universal" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.VisualStudioExtension" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.Webcrossplat" />
    <IncludeWorkload Include="Microsoft.VisualStudio.Workload.Python" />
  </ItemGroup>
	
	<Import Project="$(PackagesPath)\Microsoft.DevDiv.Validation.TestPlatform.Settings.Tasks.1.0.1108\build\net472\Microsoft.DevDiv.Validation.TestPlatform.Settings.Tasks.targets"/>

  <!-- This has to come after the .targets import or else it won't get written out. -->
  <ItemGroup Label="Test Adapter Settings">
    <AdditionalSettings Include="MSTest">
      <Settings>
        <MapInconclusiveToFailed>False</MapInconclusiveToFailed>
        <CaptureTraceOutput>True</CaptureTraceOutput>
        <DeleteDeploymentDirectoryAfterTestRunIsComplete>True</DeleteDeploymentDirectoryAfterTestRunIsComplete>
        <DeploymentEnabled>False</DeploymentEnabled>
        <TestTimeout>300000</TestTimeout>
      </Settings>
    </AdditionalSettings>
  </ItemGroup>
</Project>